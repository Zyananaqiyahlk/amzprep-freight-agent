# ─────────────────────────────────────────────────────────────
# AMZ Prep Freight Bidding Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ── Anthropic / Claude ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets ──────────────────────────────────────────────
# Create a service account in Google Cloud Console
# Share your spreadsheet with the service account email
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=freight-agent@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── HubSpot ────────────────────────────────────────────────────
# Create a private app in HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.deals.read, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# ── Carrier Email Addresses ────────────────────────────────────
# Replace with actual carrier contact emails
CARRIER_EMAIL_AMAZON=amazon-freight@example.com
CARRIER_EMAIL_UPS=ups-freight@example.com
CARRIER_EMAIL_FEDEX=fedex-freight@example.com
CARRIER_EMAIL_XPO=xpo@example.com
CARRIER_EMAIL_OLD_DOMINION=odfl@example.com
CARRIER_EMAIL_ESTES=estes@example.com

# ── Gmail (for n8n integration) ────────────────────────────────
# Configure OAuth2 credentials in n8n directly
# These are documented here for reference only
GMAIL_FREIGHT_ADDRESS=freight@amzprep.com
